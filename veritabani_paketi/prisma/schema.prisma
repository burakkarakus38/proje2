generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Role Enum ─────────────────────────────────────────────────────
enum Role {
  DRIVER
  OPERATOR
  ADMIN
}

// ── User Model ────────────────────────────────────────────────────
model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  name         String?
  role         Role           @default(DRIVER)
  createdAt    DateTime       @default(now())
  refreshTokens RefreshToken[]

  @@map("users")
}

// ── RefreshToken Model ────────────────────────────────────────────
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}
